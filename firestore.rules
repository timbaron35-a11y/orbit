rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Prospects et données utilisateur
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId ||
        exists(/databases/$(database)/documents/collaborations/$(userId + '_' + request.auth.uid))
      );
    }

    // Collaborations actives (utilisées dans les règles ci-dessus)
    match /collaborations/{collabId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.collaboratorUid == request.auth.uid
      );
      allow create: if request.auth != null &&
        request.resource.data.collaboratorUid == request.auth.uid;
      allow delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.collaboratorUid == request.auth.uid
      );
    }

    // Invitations
    match /invitations/{invId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.collaboratorEmail == request.auth.token.email
      );
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.collaboratorEmail == request.auth.token.email
      );
      allow delete: if request.auth != null &&
        resource.data.ownerId == request.auth.uid;
    }

  }
}
